<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /orderly/
    
    # Jika file/folder ada, serve langsung
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Semua request lain ke index.html
    RewriteRule ^(.*)$ index.html [L]
</IfModule>
